// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(uuid())

  name            String?
  // here, you can add custom user fields like address, fatherName etc according to your need but after this, you'll need to update

  email           String   @unique
  password        String
  emailVerified   Boolean  @default(false)

  tokens          Token[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Token {
  id          String     @id @default(uuid())
  userId      String
  type        TokenType
  tokenHash   String
  device      String? 
  expiresAt   DateTime
  createdAt   DateTime   @default(now())
  deviceName String?
  
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash]) // because we will be finding the token using its tokenHash
  @@unique([userId, device, type])
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  REFRESH_TOKEN
}