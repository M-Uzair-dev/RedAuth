{
  "name": "authtemplate",
  "version": "1.0.0",
  "description": "Secure authentication boilerplate using TypeScript, Express, PostgreSQL, Prisma, and Redis with JWT, refresh tokens, and rate limiting. All code is hand-written, and contains zero AI-generated code.",
  "keywords": [
    "express",
    "nodejs",
    "typescript",
    "authentication",
    "auth-template",
    "jwt",
    "refresh-token",
    "access-token",
    "secure-auth",
    "postgresql",
    "prisma",
    "redis",
    "rate-limiting",
    "api-security",
    "session-management",
    "http-only-cookies",
    "zod",
    "validation",
    "backend-template",
    "boilerplate"
  ],
  "homepage": "https://github.com/M-Uzair-dev/Authetication-Template#readme",
  "bugs": {
    "url": "https://github.com/M-Uzair-dev/Authetication-Template/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/M-Uzair-dev/Authetication-Template.git"
  },
  "license": "ISC",
  "author": "Uzair Manan",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && copyfiles -u 1 src/emails/*.html dist/",
    "dev": "concurrently \"tsc -w\" \"nodemon --watch dist --delay 1.5 dist/index.js\"",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run src/tests/unit",
    "test:integration": "vitest run src/tests/integration"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.6.0",
    "bcrypt": "^6.0.0",
    "build": "^0.1.4",
    "bullmq": "^5.71.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.3",
    "npm": "^11.12.1",
    "pg": "^8.20.0",
    "run": "^1.5.0",
    "typescript": "^5.9.3",
    "ua-parser-js": "^2.0.9",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.13.0",
    "@testcontainers/redis": "^11.13.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/helmet": "^0.0.48",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/ua-parser-js": "^0.7.39",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.2.1",
    "copyfiles": "^2.4.1",
    "nodemon": "^3.1.14",
    "prisma": "^7.6.0",
    "supertest": "^7.2.2",
    "tsc-node": "^0.0.3",
    "vitest": "^4.1.2"
  }
}
